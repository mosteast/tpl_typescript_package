  "author": "Mosteast team",
  "type": "module",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.cjs"
    }
  },
  "main": "build/index.cjs",
  "module": "build/index.js",
  "browser": "build/index.global.js",
  "types": "build/index.d.ts",
  "files": [
    "build/"
  ],
  "scripts": {
    "build": "npx tsup",
    "fix": "ESLINT_USE_FLAT_CONFIG=false npx eslint --fix . --ext .js,.jsx,.ts,.tsx",
    "format": "npx sort-package-json && git diff --name-only -z --diff-filter=ACMR | xargs -0 npx prettier --write --ignore-unknown",
    "go": "npm run build && npm publish --access public",
    "inherit": "for branch in master; do git pull --no-edit --allow-unrelated-histories git@github.com:mosteast/tpl_typescript_package.git $branch; done",
    "lint": "ESLINT_USE_FLAT_CONFIG=false npx eslint . --ext .js,.jsx,.ts,.tsx",
    "prepublishOnly": "npm run build && npm test",
    "release": "npm publish --access public",
    "test": "NODE_ENV=test npx vitest"
  },
  "dependencies": {
    "@mosteast/common_eid": "^0.2.0",
    "@mosteast/e": "^0.2.2",
    "debug": "^4.4.3",
    "dotenv": "^17.4.2",
    "lodash-es": "^4.18.1"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.9.1",
    "@types/shelljs": "^0.10.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitest/eslint-plugin": "^1.6.19",
    "eslint": "^10.4.1",
    "eslint-plugin-import": "^2.32.0",
    "fs-extra": "^11.3.5",
    "prettier": "^3.8.3",
    "shelljs": "^0.10.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "utility-types": "^3.11.0",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18"
  }
}
